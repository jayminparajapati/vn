<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jaimin Katakiya — Frontend Developer</title>
<meta name="description" content="Jaimin Katakiya — Passionate Frontend Web Developer from Ahmedabad. Specializing in React, Next.js, Supabase, and beautiful UI/UX.">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --c1: #FF3CAC; --c2: #784BA0; --c3: #2B86C5; --c4: #00F5D4;
  --c5: #FFE600; --c6: #FF6B35; --dark: #07070F; --light: #F5F0FF;
  --glass: rgba(255,255,255,0.05); --glass-border: rgba(255,255,255,0.1);
}
html { scroll-behavior: smooth; }
body { font-family: 'Outfit', sans-serif; background: var(--dark); color: var(--light); overflow-x: hidden; cursor: none; }

/* CURSOR */
.cursor { position: fixed; top:0; left:0; width:18px; height:18px; background:var(--c1); border-radius:50%; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition:transform 0.1s, width 0.25s, height 0.25s; mix-blend-mode:screen; }
.cursor-ring { position:fixed; top:0; left:0; width:42px; height:42px; border:2px solid var(--c4); border-radius:50%; pointer-events:none; z-index:9998; transform:translate(-50%,-50%); transition:width 0.25s,height 0.25s; opacity:0.5; }

/* NAV */
nav { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; justify-content:space-between; align-items:center; padding:1.1rem 4rem; background:rgba(7,7,15,0.75); backdrop-filter:blur(20px); border-bottom:1px solid var(--glass-border); }
.nav-logo { font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:900; font-style:italic; background:linear-gradient(135deg,var(--c1),var(--c4)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.nav-links { display:flex; gap:2.5rem; list-style:none; }
.nav-links a { font-family:'Space Mono',monospace; font-size:0.73rem; color:rgba(245,240,255,0.55); text-decoration:none; text-transform:uppercase; letter-spacing:2px; transition:color 0.3s; position:relative; }
.nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:2px; background:linear-gradient(90deg,var(--c1),var(--c4)); transition:width 0.3s; }
.nav-links a:hover { color:var(--light); } .nav-links a:hover::after { width:100%; }
.hamburger { display:none; flex-direction:column; gap:5px; cursor:pointer; z-index:200; }
.hamburger span { display:block; width:26px; height:2px; background:var(--light); transition:all 0.3s; }
.nav-overlay { display:none; position:fixed; inset:0; background:rgba(7,7,15,0.97); backdrop-filter:blur(20px); z-index:150; flex-direction:column; align-items:center; justify-content:center; gap:2rem; }
.nav-overlay.open { display:flex; }
.nav-overlay a { font-family:'Playfair Display',serif; font-size:2.5rem; font-weight:700; font-style:italic; color:var(--light); text-decoration:none; transition:color 0.3s; }
.nav-overlay a:hover { color:var(--c1); }

/* HERO */
.hero { position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; }
.hero-bg { position:absolute; inset:0; background:radial-gradient(ellipse at 15% 55%,rgba(255,60,172,0.22) 0%,transparent 60%), radial-gradient(ellipse at 80% 15%,rgba(0,245,212,0.18) 0%,transparent 55%), radial-gradient(ellipse at 65% 85%,rgba(43,134,197,0.18) 0%,transparent 55%), var(--dark); }
.hero-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px); background-size:60px 60px; mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%); }
.floating-orbs { position:absolute; inset:0; pointer-events:none; }
.orb { position:absolute; border-radius:50%; filter:blur(70px); animation:floatOrb 9s ease-in-out infinite; }
.orb-1 { width:420px; height:420px; background:rgba(255,60,172,0.16); top:-80px; right:-80px; animation-delay:0s; }
.orb-2 { width:320px; height:320px; background:rgba(0,245,212,0.13); bottom:-40px; left:8%; animation-delay:-4s; }
.orb-3 { width:260px; height:260px; background:rgba(120,75,160,0.18); top:38%; right:22%; animation-delay:-6s; }
@keyframes floatOrb { 0%,100%{transform:translateY(0) scale(1);} 50%{transform:translateY(-35px) scale(1.06);} }

.hero-content { position:relative; padding:0 4rem; max-width:950px; z-index:2; }
.hero-tag { display:inline-flex; align-items:center; gap:8px; font-family:'Space Mono',monospace; font-size:0.7rem; letter-spacing:3px; text-transform:uppercase; color:var(--c4); padding:0.4rem 1rem; border:1px solid rgba(0,245,212,0.3); border-radius:100px; margin-bottom:1.8rem; animation:fadeUp 0.8s ease both; }
.hero-tag::before { content:'●'; font-size:0.55rem; color:var(--c4); animation:blink 1.5s infinite; }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

.hero-name { font-family:'Playfair Display',serif; font-size:clamp(3.5rem,8vw,6.8rem); font-weight:900; line-height:1; letter-spacing:-2px; margin-bottom:0.4rem; animation:fadeUp 0.8s 0.15s ease both; }
.hero-name span { display:block; }
.gradient-text { background:linear-gradient(135deg,var(--c1) 0%,var(--c5) 40%,var(--c4) 80%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }

.hero-title { font-family:'Space Mono',monospace; font-size:clamp(0.8rem,1.8vw,1rem); color:rgba(245,240,255,0.45); letter-spacing:4px; text-transform:uppercase; margin-bottom:2rem; animation:fadeUp 0.8s 0.3s ease both; }
.hero-desc { font-size:1.08rem; line-height:1.85; color:rgba(245,240,255,0.62); max-width:560px; margin-bottom:3rem; animation:fadeUp 0.8s 0.45s ease both; }
.hero-cta { display:flex; gap:1.2rem; flex-wrap:wrap; animation:fadeUp 0.8s 0.6s ease both; }
.btn-primary { padding:0.9rem 2.2rem; background:linear-gradient(135deg,var(--c1),var(--c2)); color:white; border:none; border-radius:100px; font-family:'Outfit',sans-serif; font-size:0.95rem; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:transform 0.3s,box-shadow 0.3s; box-shadow:0 0 30px rgba(255,60,172,0.3); }
.btn-primary:hover { transform:translateY(-3px); box-shadow:0 12px 40px rgba(255,60,172,0.5); }
.btn-secondary { padding:0.9rem 2.2rem; background:var(--glass); color:var(--light); border:1px solid var(--glass-border); border-radius:100px; font-family:'Outfit',sans-serif; font-size:0.95rem; font-weight:500; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.3s; backdrop-filter:blur(10px); }
.btn-secondary:hover { background:rgba(255,255,255,0.1); transform:translateY(-3px); border-color:var(--c4); color:var(--c4); }

/* Typewriter */
.typewriter { display:inline-block; border-right:3px solid var(--c1); padding-right:4px; animation:caretBlink 0.75s step-end infinite; }
@keyframes caretBlink { 0%,100%{border-color:var(--c1);} 50%{border-color:transparent;} }

.hero-scroll { position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:8px; font-family:'Space Mono',monospace; font-size:0.62rem; letter-spacing:2px; color:rgba(245,240,255,0.3); animation:fadeUp 1s 1.2s ease both; }
.scroll-line { width:1px; height:55px; background:linear-gradient(var(--c1),transparent); animation:scrollPulse 2s infinite; }
@keyframes scrollPulse { 0%{transform:scaleY(0);transform-origin:top;opacity:0;} 50%{transform:scaleY(1);transform-origin:top;opacity:1;} 100%{transform:scaleY(0);transform-origin:bottom;opacity:0;} }
@keyframes fadeUp { from{opacity:0;transform:translateY(28px);} to{opacity:1;transform:translateY(0);} }

/* MARQUEE */
.marquee-section { padding:2.5rem 0; background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3),var(--c4),var(--c5),var(--c6)); overflow:hidden; }
.marquee-track { display:flex; gap:2.5rem; animation:marquee 22s linear infinite; white-space:nowrap; }
.marquee-track span { font-family:'Playfair Display',serif; font-size:1.3rem; font-style:italic; font-weight:700; color:rgba(7,7,15,0.65); flex-shrink:0; }
.marquee-track span.dot { color:rgba(7,7,15,0.35); }
@keyframes marquee { from{transform:translateX(0);} to{transform:translateX(-50%);} }

/* ABOUT */
#about { padding:8rem 4rem; background:linear-gradient(180deg,var(--dark) 0%,#0C0C1E 100%); }
.about-grid { display:grid; grid-template-columns:1fr 1.2fr; gap:5rem; align-items:center; max-width:1200px; margin:0 auto; }
.about-photo-frame { width:100%; aspect-ratio:4/5; background:linear-gradient(145deg,#1a1a2e,#16213e,#0f3460); border-radius:28px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; border:1px solid var(--glass-border); }
.avatar-initials { font-family:'Playfair Display',serif; font-size:7rem; font-weight:900; font-style:italic; background:linear-gradient(135deg,var(--c1),var(--c4)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; z-index:2; position:relative; }
.avatar-ring { position:absolute; width:200px; height:200px; border-radius:50%; border:2px solid rgba(255,60,172,0.2); animation:spinRing 20s linear infinite; }
.avatar-ring:nth-child(2) { width:280px; height:280px; border-color:rgba(0,245,212,0.15); animation-direction:reverse; animation-duration:15s; }
@keyframes spinRing { from{transform:rotate(0deg);} to{transform:rotate(360deg);} }
.about-badge { position:absolute; bottom:-18px; right:-18px; width:110px; height:110px; background:linear-gradient(135deg,var(--c5),var(--c6)); border-radius:50%; display:flex; flex-direction:column; align-items:center; justify-content:center; font-weight:700; font-size:0.7rem; text-align:center; color:var(--dark); line-height:1.3; box-shadow:0 10px 35px rgba(255,230,0,0.35); }
.about-badge strong { font-size:1.7rem; display:block; line-height:1; }
.about-text .section-label { font-family:'Space Mono',monospace; font-size:0.7rem; letter-spacing:4px; text-transform:uppercase; color:var(--c4); margin-bottom:0.8rem; }
.about-text .section-title { font-family:'Playfair Display',serif; font-size:clamp(2rem,3.5vw,3rem); font-weight:900; line-height:1.1; letter-spacing:-1px; margin-bottom:1.5rem; }
.about-text p { color:rgba(245,240,255,0.62); line-height:1.9; margin-bottom:1.1rem; font-size:1.03rem; }
.about-stats { display:flex; gap:1.2rem; margin-top:2.5rem; flex-wrap:wrap; }
.stat { text-align:center; padding:1.1rem 1.4rem; background:var(--glass); border:1px solid var(--glass-border); border-radius:16px; backdrop-filter:blur(10px); min-width:85px; }
.stat-num { font-family:'Playfair Display',serif; font-size:2rem; font-weight:900; background:linear-gradient(135deg,var(--c1),var(--c4)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; line-height:1; }
.stat-label { font-size:0.68rem; color:rgba(245,240,255,0.38); font-family:'Space Mono',monospace; letter-spacing:1px; margin-top:4px; }

/* SKILLS */
#skills { padding:8rem 4rem; background:#0C0C1E; overflow:hidden; }
#skills .inner, #projects .inner, #experience .inner { max-width:1200px; margin:0 auto; }
.section-label { font-family:'Space Mono',monospace; font-size:0.7rem; letter-spacing:4px; text-transform:uppercase; color:var(--c4); margin-bottom:0.8rem; display:block; }
.section-title { font-family:'Playfair Display',serif; font-size:clamp(2.2rem,4vw,3.3rem); font-weight:900; line-height:1.1; letter-spacing:-1px; margin-bottom:3.5rem; }
.skills-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:1.5rem; }
.skill-card { padding:2rem; background:var(--glass); border:1px solid var(--glass-border); border-radius:20px; backdrop-filter:blur(10px); transition:transform 0.3s,border-color 0.3s,box-shadow 0.3s; position:relative; overflow:hidden; }
.skill-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:var(--cg); }
.skill-card:hover { transform:translateY(-8px); border-color:rgba(255,255,255,0.18); box-shadow:0 20px 55px rgba(0,0,0,0.4); }
.s1{--cg:linear-gradient(90deg,var(--c1),var(--c2));}
.s2{--cg:linear-gradient(90deg,var(--c3),var(--c4));}
.s3{--cg:linear-gradient(90deg,var(--c5),var(--c6));}
.s4{--cg:linear-gradient(90deg,var(--c2),var(--c3));}
.skill-icon { font-size:2.4rem; margin-bottom:1rem; }
.skill-title { font-family:'Playfair Display',serif; font-size:1.25rem; font-weight:700; margin-bottom:1rem; }
.skill-tags { display:flex; flex-wrap:wrap; gap:0.45rem; }
.tag { font-family:'Space Mono',monospace; font-size:0.62rem; letter-spacing:1px; padding:0.28rem 0.75rem; border:1px solid rgba(255,255,255,0.11); border-radius:100px; color:rgba(245,240,255,0.58); transition:all 0.2s; }
.tag:hover { background:rgba(255,255,255,0.07); color:var(--light); }

/* PROJECTS */
#projects { padding:8rem 4rem; background:linear-gradient(180deg,#0C0C1E 0%,var(--dark) 100%); }
.projects-grid { display:grid; grid-template-columns:repeat(12,1fr); gap:1.5rem; }
.project-card { background:var(--glass); border:1px solid var(--glass-border); border-radius:24px; overflow:hidden; transition:transform 0.4s,box-shadow 0.4s; }
.project-card:hover { transform:translateY(-10px); box-shadow:0 30px 80px rgba(0,0,0,0.5); }
.project-card:nth-child(1) { grid-column:span 7; }
.project-card:nth-child(2) { grid-column:span 5; }
.project-card:nth-child(3) { grid-column:span 5; }
.project-card:nth-child(4) { grid-column:span 7; }
.project-thumb { width:100%; aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; font-size:4rem; position:relative; overflow:hidden; border-bottom:1px solid var(--glass-border); }
.p1 .project-thumb { background:linear-gradient(135deg,rgba(255,60,172,.15),rgba(120,75,160,.2)); }
.p2 .project-thumb { background:linear-gradient(135deg,rgba(0,245,212,.12),rgba(43,134,197,.18)); }
.p3 .project-thumb { background:linear-gradient(135deg,rgba(255,230,0,.12),rgba(255,107,53,.18)); }
.p4 .project-thumb { background:linear-gradient(135deg,rgba(120,75,160,.15),rgba(255,60,172,.12)); }
.thumb-glow { position:absolute; inset:0; background:radial-gradient(circle at center,rgba(255,255,255,0.05),transparent 70%); }
.project-info { padding:1.7rem; }
.project-number { font-family:'Space Mono',monospace; font-size:0.62rem; letter-spacing:3px; color:var(--c4); margin-bottom:0.4rem; }
.project-name { font-family:'Playfair Display',serif; font-size:1.35rem; font-weight:700; margin-bottom:0.45rem; }
.project-desc { font-size:0.88rem; color:rgba(245,240,255,0.5); line-height:1.7; margin-bottom:1.1rem; }
.project-link { display:inline-flex; align-items:center; gap:6px; font-family:'Space Mono',monospace; font-size:0.68rem; letter-spacing:2px; text-transform:uppercase; color:var(--c1); text-decoration:none; transition:gap 0.2s; }
.project-link:hover { gap:10px; }
.project-tech { display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:1rem; }
.project-tech span { font-family:'Space Mono',monospace; font-size:0.58rem; padding:0.2rem 0.6rem; border:1px solid rgba(255,60,172,0.25); border-radius:100px; color:rgba(255,60,172,0.8); }

/* EXPERIENCE */
#experience { padding:8rem 4rem; background:var(--dark); }
.timeline { position:relative; padding-left:2rem; }
.timeline::before { content:''; position:absolute; left:0; top:10px; bottom:0; width:2px; background:linear-gradient(180deg,var(--c1),var(--c3),transparent); }
.timeline-item { position:relative; padding-left:2.5rem; margin-bottom:3.5rem; opacity:0; transform:translateX(-20px); transition:opacity 0.6s,transform 0.6s; }
.timeline-item.visible { opacity:1; transform:translateX(0); }
.timeline-dot { position:absolute; left:-2rem; top:6px; width:14px; height:14px; border-radius:50%; border:2px solid var(--c1); background:var(--dark); box-shadow:0 0 15px var(--c1); }
.tl-period { font-family:'Space Mono',monospace; font-size:0.66rem; letter-spacing:2px; color:var(--c4); margin-bottom:0.4rem; }
.tl-role { font-family:'Playfair Display',serif; font-size:1.45rem; font-weight:700; margin-bottom:0.2rem; }
.tl-company { font-size:0.9rem; color:var(--c1); font-weight:500; margin-bottom:0.8rem; }
.tl-desc { color:rgba(245,240,255,0.55); line-height:1.85; font-size:0.93rem; max-width:650px; }

/* EDUCATION */
#education { padding:8rem 4rem; background:#0C0C1E; }
#education .inner { max-width:1200px; margin:0 auto; }
.edu-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.5rem; }
.edu-card { padding:2.2rem; background:var(--glass); border:1px solid var(--glass-border); border-radius:20px; backdrop-filter:blur(10px); position:relative; overflow:hidden; transition:transform 0.3s,box-shadow 0.3s; }
.edu-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,var(--c2),var(--c3)); }
.edu-card:hover { transform:translateY(-6px); box-shadow:0 20px 50px rgba(0,0,0,0.4); }
.edu-icon { font-size:2.5rem; margin-bottom:1rem; }
.edu-year { font-family:'Space Mono',monospace; font-size:0.66rem; letter-spacing:2px; color:var(--c4); margin-bottom:0.4rem; }
.edu-degree { font-family:'Playfair Display',serif; font-size:1.2rem; font-weight:700; margin-bottom:0.3rem; }
.edu-institution { font-size:0.88rem; color:rgba(245,240,255,0.5); line-height:1.5; }

/* CONTACT */
#contact { padding:8rem 4rem; background:var(--dark); text-align:center; position:relative; overflow:hidden; }
#contact::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at center,rgba(255,60,172,0.1) 0%,transparent 70%); pointer-events:none; }
.contact-title { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,5vw,4.2rem); font-weight:900; letter-spacing:-2px; margin:0.8rem 0 1.2rem; background:linear-gradient(135deg,var(--light) 0%,rgba(245,240,255,0.4) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
#contact > p { color:rgba(245,240,255,0.48); font-size:1.03rem; max-width:480px; margin:0 auto 3rem; line-height:1.8; }
.contact-info-cards { display:flex; justify-content:center; gap:1.2rem; flex-wrap:wrap; margin-bottom:3rem; }
.info-card { display:flex; align-items:center; gap:0.8rem; padding:1rem 1.6rem; background:var(--glass); border:1px solid var(--glass-border); border-radius:100px; font-size:0.9rem; color:rgba(245,240,255,0.7); backdrop-filter:blur(10px); text-decoration:none; transition:all 0.3s; }
.info-card:hover { border-color:var(--c1); color:var(--c1); transform:translateY(-3px); }
.info-card .ic { font-size:1.1rem; }
.contact-form { max-width:600px; margin:0 auto; display:flex; flex-direction:column; gap:1.2rem; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; }
.form-field { display:flex; flex-direction:column; gap:0.4rem; text-align:left; }
.form-field label { font-family:'Space Mono',monospace; font-size:0.62rem; letter-spacing:2px; text-transform:uppercase; color:rgba(245,240,255,0.38); }
.form-field input, .form-field textarea { background:var(--glass); border:1px solid var(--glass-border); border-radius:12px; padding:0.9rem 1.2rem; color:var(--light); font-family:'Outfit',sans-serif; font-size:0.93rem; outline:none; transition:border-color 0.3s,box-shadow 0.3s; resize:none; }
.form-field input:focus, .form-field textarea:focus { border-color:var(--c1); box-shadow:0 0 20px rgba(255,60,172,0.12); }
.form-field input::placeholder, .form-field textarea::placeholder { color:rgba(245,240,255,0.18); }
.form-submit { padding:1rem 3rem; background:linear-gradient(135deg,var(--c1),var(--c2),var(--c3)); border:none; border-radius:100px; color:white; font-family:'Outfit',sans-serif; font-size:1rem; font-weight:600; cursor:pointer; transition:transform 0.3s,box-shadow 0.3s; box-shadow:0 0 40px rgba(255,60,172,0.25); background-size:200%; }
.form-submit:hover { transform:translateY(-3px); box-shadow:0 15px 50px rgba(255,60,172,0.45); }
.social-links { display:flex; justify-content:center; gap:1.2rem; margin-top:4rem; }
.social-link { display:flex; align-items:center; justify-content:center; gap:8px; padding:0.75rem 1.4rem; background:var(--glass); border:1px solid var(--glass-border); border-radius:100px; color:rgba(245,240,255,0.6); text-decoration:none; font-size:0.85rem; font-family:'Space Mono',monospace; letter-spacing:1px; transition:all 0.3s; backdrop-filter:blur(10px); }
.social-link:hover { background:var(--c1); border-color:var(--c1); color:white; transform:translateY(-3px); box-shadow:0 10px 30px rgba(255,60,172,0.35); }

/* FOOTER */
footer { padding:2rem 4rem; background:var(--dark); border-top:1px solid var(--glass-border); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; }
footer p { font-family:'Space Mono',monospace; font-size:0.68rem; color:rgba(245,240,255,0.28); letter-spacing:1px; }
.footer-logo { font-family:'Playfair Display',serif; font-size:1.2rem; font-weight:900; font-style:italic; background:linear-gradient(135deg,var(--c1),var(--c4)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }

/* MOBILE */
@media(max-width:900px){
  nav{padding:1.1rem 2rem;} .nav-links{display:none;} .hamburger{display:flex;}
  .hero-content{padding:0 2rem;}
  .about-grid{grid-template-columns:1fr;gap:3rem;}
  .about-image-wrap{max-width:380px;margin:0 auto;}
  .projects-grid{grid-template-columns:1fr;}
  .project-card:nth-child(n){grid-column:span 1;}
  #about,#skills,#projects,#experience,#education,#contact{padding:5rem 2rem;}
  .form-row{grid-template-columns:1fr;}
  footer{flex-direction:column;text-align:center;padding:2rem;}
  .about-stats{justify-content:center;}
  .contact-info-cards{flex-direction:column;align-items:center;}
  .social-links{flex-wrap:wrap;}
}
@media(max-width:480px){
  .hero-name{font-size:3rem;}
  .hero-cta{flex-direction:column;}
  .btn-primary,.btn-secondary{justify-content:center;}
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay">
  <a href="#about" onclick="closeNav()">About</a>
  <a href="#skills" onclick="closeNav()">Skills</a>
  <a href="#projects" onclick="closeNav()">Work</a>
  <a href="#experience" onclick="closeNav()">Experience</a>
  <a href="#contact" onclick="closeNav()">Contact</a>
</div>

<!-- NAV -->
<nav>
  <div class="nav-logo">JK.</div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Work</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="hamburger" id="hamburger" onclick="toggleNav()">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-grid" data-parallax data-speed="0.2"></div>
  <div class="floating-orbs">
    <div class="orb orb-1" data-parallax data-speed="0.3"></div>
    <div class="orb orb-2" data-parallax data-speed="0.15"></div>
    <div class="orb orb-3" data-parallax data-speed="0.25"></div>
  </div>
  <div class="hero-content">
    <div class="hero-tag">Open to Internships &amp; Trainee Roles</div>
    <h1 class="hero-name">
      <span>Jaimin</span>
      <span class="gradient-text">Katakiya.</span>
    </h1>
    <p class="hero-title"><span class="typewriter" id="typewriter">Frontend Developer</span></p>
    <p class="hero-desc">I build visually stunning, high-performance, and responsive user interfaces. Passionate about turning complex designs into clean, functional code that provides a seamless user experience.</p>
    <div class="hero-cta">
      <a href="#projects" class="btn-primary">View My Work →</a>
      <a href="https://my-devlopoent.vercel.app/" target="_blank" class="btn-secondary">🌐 Live Portfolio</a>
    </div>
  </div>
  <div class="hero-scroll"><div class="scroll-line"></div>SCROLL</div>
</section>

<!-- MARQUEE -->
<div class="marquee-section" aria-hidden="true">
  <div class="marquee-track">
    <span>Next.js</span><span class="dot">✦</span><span>React</span><span class="dot">✦</span>
    <span>Supabase</span><span class="dot">✦</span><span>MongoDB</span><span class="dot">✦</span>
    <span>JavaScript</span><span class="dot">✦</span><span>HTML5</span><span class="dot">✦</span>
    <span>CSS3</span><span class="dot">✦</span><span>Git</span><span class="dot">✦</span>
    <span>Responsive Design</span><span class="dot">✦</span><span>UI/UX</span><span class="dot">✦</span>
    <!-- duplicate -->
    <span>Next.js</span><span class="dot">✦</span><span>React</span><span class="dot">✦</span>
    <span>Supabase</span><span class="dot">✦</span><span>MongoDB</span><span class="dot">✦</span>
    <span>JavaScript</span><span class="dot">✦</span><span>HTML5</span><span class="dot">✦</span>
    <span>CSS3</span><span class="dot">✦</span><span>Git</span><span class="dot">✦</span>
    <span>Responsive Design</span><span class="dot">✦</span><span>UI/UX</span><span class="dot">✦</span>
  </div>
</div>

<!-- ABOUT -->
<section id="about">
  <div class="about-grid">
    <div class="about-image-wrap" data-parallax data-speed="0.08">
      <div class="about-photo-frame">
        <div class="avatar-ring"></div>
        <div class="avatar-ring"></div>
        <div class="avatar-initials">JK</div>
      </div>
      <div class="about-badge"><strong>1+</strong>Year<br>Experience</div>
    </div>
    <div class="about-text">
      <span class="section-label">// About Me</span>
      <h2 class="section-title">Building Beautiful<br><em style="color:var(--c1)">Web Experiences</em></h2>
      <p>Hi! I'm Jaimin Katakiya, a passionate Frontend Web Developer based in Greater Ahmedabad, Gujarat. I'm dedicated to building visually stunning, high-performance, and responsive user interfaces.</p>
      <p>With a strong foundation in HTML, CSS, and JavaScript, I focus on turning complex designs into clean, functional code. Currently expanding my expertise in modern web technologies like Next.js, Supabase, and MongoDB while working as a Trainee at Codestrom Group.</p>
      <p>I thrive on solving UI/UX challenges and am always eager to learn and implement the latest industry standards. I'm seeking opportunities to contribute to innovative projects.</p>
      <div class="about-stats">
        <div class="stat"><div class="stat-num">5+</div><div class="stat-label">Projects</div></div>
        <div class="stat"><div class="stat-num">1+</div><div class="stat-label">Years</div></div>
        <div class="stat"><div class="stat-num">3</div><div class="stat-label">Top Skills</div></div>
        <div class="stat"><div class="stat-num">100%</div><div class="stat-label">Passion</div></div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section id="skills">
  <div class="inner">
    <span class="section-label">// Technical Toolkit</span>
    <h2 class="section-title">What I Work With</h2>
    <div class="skills-grid">
      <div class="skill-card s1">
        <div class="skill-icon">⚡</div>
        <div class="skill-title">Frontend Languages</div>
        <div class="skill-tags">
          <span class="tag">HTML5</span><span class="tag">CSS3</span>
          <span class="tag">JavaScript ES6+</span><span class="tag">TypeScript</span>
        </div>
      </div>
      <div class="skill-card s2">
        <div class="skill-icon">🚀</div>
        <div class="skill-title">Frameworks & Libraries</div>
        <div class="skill-tags">
          <span class="tag">Next.js</span><span class="tag">React</span>
          <span class="tag">Tailwind CSS</span><span class="tag">Framer Motion</span>
        </div>
      </div>
      <div class="skill-card s3">
        <div class="skill-icon">🗄️</div>
        <div class="skill-title">Backend & Database</div>
        <div class="skill-tags">
          <span class="tag">Supabase</span><span class="tag">MongoDB</span>
          <span class="tag">REST API</span><span class="tag">Node.js</span>
        </div>
      </div>
      <div class="skill-card s4">
        <div class="skill-icon">🛠️</div>
        <div class="skill-title">Tools & Practices</div>
        <div class="skill-tags">
          <span class="tag">Git/GitHub</span><span class="tag">VS Code</span>
          <span class="tag">Chrome DevTools</span><span class="tag">Responsive Design</span>
          <span class="tag">Cross-Browser</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects">
  <div class="inner">
    <span class="section-label">// Featured Work</span>
    <h2 class="section-title">Projects I've Built</h2>
    <div class="projects-grid">
      <div class="project-card p1">
        <div class="project-thumb"><span>🌐</span><div class="thumb-glow"></div></div>
        <div class="project-info">
          <div class="project-number">PROJECT 01</div>
          <div class="project-name">Personal Portfolio</div>
          <div class="project-tech"><span>Next.js</span><span>Tailwind</span><span>Vercel</span></div>
          <div class="project-desc">A sleek, performant personal portfolio deployed on Vercel — showcasing projects, skills, and personality through clean code and great design.</div>
          <a href="https://my-devlopoent.vercel.app/" target="_blank" class="project-link">Live Site →</a>
        </div>
      </div>
      <div class="project-card p2">
        <div class="project-thumb"><span>🔐</span><div class="thumb-glow"></div></div>
        <div class="project-info">
          <div class="project-number">PROJECT 02</div>
          <div class="project-name">Auth App with Supabase</div>
          <div class="project-tech"><span>Next.js</span><span>Supabase</span><span>CSS3</span></div>
          <div class="project-desc">Full authentication system with login, signup, OAuth, and protected routes using Supabase's powerful backend-as-a-service.</div>
          <a href="#" class="project-link">View Project →</a>
        </div>
      </div>
      <div class="project-card p3">
        <div class="project-thumb"><span>📦</span><div class="thumb-glow"></div></div>
        <div class="project-info">
          <div class="project-number">PROJECT 03</div>
          <div class="project-name">MongoDB CRUD App</div>
          <div class="project-tech"><span>React</span><span>MongoDB</span><span>Node.js</span></div>
          <div class="project-desc">A full-stack CRUD application demonstrating data persistence, API integration, and responsive UI with MongoDB as the database layer.</div>
          <a href="#" class="project-link">View Project →</a>
        </div>
      </div>
      <div class="project-card p4">
        <div class="project-thumb"><span>🎨</span><div class="thumb-glow"></div></div>
        <div class="project-info">
          <div class="project-number">PROJECT 04</div>
          <div class="project-name">Responsive UI Components</div>
          <div class="project-tech"><span>HTML5</span><span>CSS3</span><span>JavaScript</span></div>
          <div class="project-desc">A curated library of beautiful, mobile-first UI components — cards, modals, navbars, forms — built with vanilla web technologies.</div>
          <a href="#" class="project-link">View Project →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience">
  <div class="inner">
    <span class="section-label">// My Journey</span>
    <h2 class="section-title">Work Experience</h2>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="tl-period">March 2025 — Present · 1 yr 3 mo</div>
        <div class="tl-role">Trainee Developer</div>
        <div class="tl-company">Codestrom Group · Bhavnagar, Gujarat</div>
        <div class="tl-desc">Working as a trainee frontend developer, contributing to real-world web projects. Building responsive UIs, implementing modern JavaScript patterns, and collaborating with the team to deliver clean, maintainable code. Gaining hands-on experience with industry tools and workflows including Git, VS Code, and Chrome DevTools.</div>
      </div>
    </div>
  </div>
</section>

<!-- EDUCATION -->
<section id="education">
  <div class="inner">
    <span class="section-label">// Academic Background</span>
    <h2 class="section-title">Education</h2>
    <div class="edu-grid">
      <div class="edu-card">
        <div class="edu-icon">🎓</div>
        <div class="edu-year">January 2021 — April 2022</div>
        <div class="edu-degree">Sardar Patel Education Institute</div>
        <div class="edu-institution">Maharaja Krishnakumarsinhji Bhavnagar University (MKBU)<br>Bhavnagar, Gujarat</div>
      </div>
      <div class="edu-card">
        <div class="edu-icon">💡</div>
        <div class="edu-year">Self-Learning · Ongoing</div>
        <div class="edu-degree">Modern Web Development</div>
        <div class="edu-institution">Continuous learning through online platforms, documentation, and hands-on projects — covering Next.js, Supabase, MongoDB, and modern JavaScript.</div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <span class="section-label">// Get In Touch</span>
  <h2 class="contact-title">Let's Work<br>Together</h2>
  <p>I'm actively looking for trainee and intern opportunities. Have a project or role in mind? Let's talk!</p>
  <div class="contact-info-cards">
    <a href="mailto:jaiminkatakiya7600@gmail.com" class="info-card"><span class="ic">✉️</span> jaiminkatakiya7600@gmail.com</a>
    <a href="https://www.linkedin.com/in/jaiminkatakiya-71602730a" target="_blank" class="info-card"><span class="ic">💼</span> LinkedIn Profile</a>
    <a href="https://my-devlopoent.vercel.app/" target="_blank" class="info-card"><span class="ic">🌐</span> Live Portfolio</a>
  </div>
  <form class="contact-form" onsubmit="handleSubmit(event)">
    <div class="form-row">
      <div class="form-field"><label>Your Name</label><input type="text" placeholder="John Doe" required></div>
      <div class="form-field"><label>Your Email</label><input type="email" placeholder="john@example.com" required></div>
    </div>
    <div class="form-field"><label>Subject</label><input type="text" placeholder="Internship / Project Inquiry" required></div>
    <div class="form-field"><label>Message</label><textarea rows="5" placeholder="Tell me about the opportunity or project..." required></textarea></div>
    <button type="submit" class="form-submit">Send Message ✨</button>
  </form>
  <div class="social-links">
    <a href="https://www.linkedin.com/in/jaiminkatakiya-71602730a" target="_blank" class="social-link">💼 LinkedIn</a>
    <a href="https://my-devlopoent.vercel.app/" target="_blank" class="social-link">🌐 Portfolio</a>
    <a href="mailto:jaiminkatakiya7600@gmail.com" class="social-link">✉️ Email</a>
  </div>
</section>

<footer>
  <div class="footer-logo">JK.</div>
  <p>© 2025 Jaimin Katakiya — Frontend Developer</p>
  <p>Greater Ahmedabad, Gujarat 🇮🇳</p>
</footer>

<script>
// CURSOR
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
function animateRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animateRing);}
animateRing();
document.querySelectorAll('a,button,.skill-card,.project-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cursor.style.transform='translate(-50%,-50%) scale(2.5)';ring.style.width='70px';ring.style.height='70px';});
  el.addEventListener('mouseleave',()=>{cursor.style.transform='translate(-50%,-50%) scale(1)';ring.style.width='42px';ring.style.height='42px';});
});

// HAMBURGER
function toggleNav(){document.getElementById('navOverlay').classList.toggle('open');}
function closeNav(){document.getElementById('navOverlay').classList.remove('open');}

// PARALLAX
(function(){
  const els=document.querySelectorAll('[data-parallax]');
  let t=false;
  window.addEventListener('scroll',()=>{
    if(!t){requestAnimationFrame(()=>{const y=window.scrollY;els.forEach(el=>{el.style.transform=`translateY(${y*(parseFloat(el.dataset.speed)||0.2)}px)`;});t=false;});t=true;}
  });
})();

// TIMELINE REVEAL
const obs=new IntersectionObserver(entries=>{entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('visible'),i*150);});},{threshold:0.2});
document.querySelectorAll('.timeline-item').forEach(el=>obs.observe(el));

// TYPEWRITER
const words=['Frontend Developer','UI/UX Enthusiast','Next.js Developer','React Developer','Web Designer'];
let wi=0,ci=0,deleting=false;
const tw=document.getElementById('typewriter');
function type(){
  const word=words[wi];
  if(!deleting){tw.textContent=word.slice(0,++ci);if(ci===word.length){deleting=true;setTimeout(type,1800);return;}}
  else{tw.textContent=word.slice(0,--ci);if(ci===0){deleting=false;wi=(wi+1)%words.length;}}
  setTimeout(type,deleting?60:100);
}
type();

// FORM
function handleSubmit(e){
  e.preventDefault();
  const btn=e.target.querySelector('.form-submit');
  btn.textContent='Message Sent! 🎉';
  btn.style.background='linear-gradient(135deg,#00F5D4,#2B86C5)';
  setTimeout(()=>{btn.textContent='Send Message ✨';btn.style.background='';e.target.reset();},3000);
}

// ACTIVE NAV
const sects=document.querySelectorAll('section[id]');
const navAs=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let cur='';
  sects.forEach(s=>{if(window.scrollY>=s.offsetTop-200)cur=s.id;});
  navAs.forEach(a=>{a.style.color=a.getAttribute('href')==='#'+cur?'var(--c4)':'';});
});
</script>
</body>
</html>